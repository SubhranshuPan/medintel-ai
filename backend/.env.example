# Copy to .env and adjust. All backend settings use the MEDINTEL_ prefix.
MEDINTEL_ENVIRONMENT=development
MEDINTEL_CORS_ORIGINS=["http://localhost:3000"]

# Async SQLAlchemy URL (asyncpg driver). Matches the docker-compose Postgres (#8).
MEDINTEL_DATABASE_URL=postgresql+asyncpg://medintel:medintel@localhost:5432/medintel

# JWT signing secret. REQUIRED outside development/test (>=32 chars) — startup
# refuses the placeholder there. Generate one with: openssl rand -hex 32
MEDINTEL_JWT_SECRET=dev-insecure-change-me
# MEDINTEL_ACCESS_TOKEN_EXPIRE_MINUTES=30
